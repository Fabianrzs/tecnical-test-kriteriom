{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Yarp": "Information"
      }
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "credits-cluster": {
        "Destinations": {
          "credits-api": { "Address": "http://localhost:5001/" }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit-api": { "Address": "http://localhost:5003/" }
        }
      },
      "batch-cluster": {
        "Destinations": {
          "batch-processor": { "Address": "http://localhost:5005/" }
        }
      }
    }
  }
}
