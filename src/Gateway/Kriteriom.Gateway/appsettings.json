{
  "Jwt": {
    "Secret": "K3r1t3r10m-Sup3rS3cr3t-JWT-K3y-2026-ForDev",
    "Issuer": "kriteriom-api-gateway",
    "Audience": "kriteriom-services",
    "ExpiryMinutes": 60
  },
  "Hangfire": {
    "DashboardUser": "admin",
    "DashboardPassword": "Hangf1r3@2026"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "Jaeger": {
    "Host": "jaeger",
    "Port": 6831
  },
  "ReverseProxy": {
    "Routes": {
      "credits-route": {
        "ClusterId": "credits-cluster",
        "Match": { "Path": "/api/credits/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/credits/{**catch-all}" }]
      },
      "clients-route": {
        "ClusterId": "credits-cluster",
        "Match": { "Path": "/api/clients/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/clients/{**catch-all}" }]
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/api/audit/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/audit/{**catch-all}" }]
      },
      "batch-route": {
        "ClusterId": "batch-cluster",
        "Match": { "Path": "/api/batch/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/api/batch/{**catch-all}" }]
      },
      "hangfire-route": {
        "ClusterId": "batch-cluster",
        "Match": { "Path": "/hangfire/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/hangfire/{**catch-all}" }]
      },
      "credits-swagger": {
        "ClusterId": "credits-cluster",
        "Match": { "Path": "/swagger/credits/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/swagger/{**catch-all}" }]
      },
      "audit-swagger": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/swagger/audit/{**catch-all}" },
        "Transforms": [{ "PathPattern": "/swagger/{**catch-all}" }]
      }
    },
    "Clusters": {
      "credits-cluster": {
        "Destinations": {
          "credits-api": { "Address": "http://credits-api:5001/" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Path": "/health"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit-api": { "Address": "http://audit-api:5003/" }
        }
      },
      "batch-cluster": {
        "Destinations": {
          "batch-processor": { "Address": "http://batch-processor:5005/" }
        }
      }
    }
  },
  "Auth": {
    "Admin":    { "Password": "Admin@2026!",    "Role": "Admin" },
    "Analyst":  { "Password": "Analyst@2026!",  "Role": "Analyst" },
    "ReadOnly": { "Password": "ReadOnly@2026!", "Role": "ReadOnly" }
  },
  "Vault": { "Address": "http://vault:8200", "Token": "root-token" },
  "AllowedHosts": "*"
}
